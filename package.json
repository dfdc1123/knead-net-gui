{
  "name": "kneadnet",
  "version": "0.2.0",
  "description": "Convert electronic schematics into breadboard layouts and routing suggestions.",
  "private": true,
  "type": "module",
  "author": "dfdc1123",
  "license": "GPL-3.0-only",
  "homepage": "https://github.com/dfdc1123/knead-net-gui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dfdc1123/knead-net-gui.git"
  },
  "bugs": {
    "url": "https://github.com/dfdc1123/knead-net-gui/issues"
  },
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test:ui": "node --test tests/*.test.mjs",
    "check:version": "node scripts/check-version.mjs",
    "package:examples": "node scripts/package-examples.mjs",
    "release:verify": "node scripts/verify-release-assets.mjs",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
