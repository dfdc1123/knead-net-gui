	source_x86_64 = KneadNet-examples-0.2.0.zip::https://github.com/dfdc1123/knead-net-gui/releases/download/v0.2.0/KneadNet-examples-0.2.0.zip
	sha256sums_x86_64 = REPLACE_WITH_DEB_SHA256
	sha256sums_x86_64 = REPLACE_WITH_EXAMPLES_SHA256

