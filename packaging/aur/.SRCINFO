pkgbase = kneadnet-bin
	pkgdesc = Convert electronic schematics into breadboard layouts and routing suggestions
	pkgver = 0.2.0
	pkgrel = 1
	url = https://github.com/dfdc1123/knead-net-gui
	arch = x86_64
	license = GPL-3.0-only
	depends = gtk3
